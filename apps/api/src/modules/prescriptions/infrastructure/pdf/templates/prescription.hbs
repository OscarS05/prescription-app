<html>
  <head>
    <meta charset='utf-8' />

    <style>
      body {
        font-family: Arial, sans-serif;
        padding: 32px;
        color: #222;
      }

      .header {
        margin-bottom: 24px;
        border-bottom: 2px solid #ddd;
        padding-bottom: 12px;

        display: flex;
        justify-content: space-between;
      }

      .header h1 {
        margin: 0;
      }

      .qr-section {
        text-align: center;
      }

      .qr-section img {
        width: 120px;
        height: 120px;
      }

      .qr-section p {
        font-size: 10px;
      }

      .section {
        margin-bottom: 20px;
      }

      .section h2 {
        margin-bottom: 8px;
        font-size: 18px;
      }

      .info-row {
        display: flex;
      }

      .field {
        width: 300px;
      }

      .label {
        font-weight: bold;
        display: block;
        margin-bottom: 4px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th {
        text-align: left;
        padding: 10px;
        border-bottom: 2px solid #ddd;
      }

      td {
        padding: 10px;
        border-bottom: 1px solid #eee;
      }

      .signature-section {
        margin-top: 100px;
        display: flex;
        justify-content: flex-start;
      }

      .signature-box {
        width: 280px;
        text-align: center;
      }

      .signature-image {
        max-width: 220px;
        max-height: 100px;
        object-fit: contain;
      }

      .signature-line {
        border-bottom: 1px solid #000;
        margin-top: 8px;
      }

      .signature-label {
        font-size: 11px;
        color: #666;
        margin-top: 4px;
      }

      .signature-name {
        font-size: 12px;
        font-weight: bold;
      }
    </style>
  </head>

  <body>
    <div class='header'>
      <div>
        <h1>Prescription</h1>

        <div class='metadata'>
          <p><strong>Code:</strong> {{code}}</p>
          <p><strong>Created at:</strong> {{createdAt}}</p>
        </div>
      </div>

      <div class='qr-section'>
        <img src='{{qrCode}}' alt='Prescription QR' />

        <p>Scan to view prescription</p>
      </div>
    </div>

    <div class='section'>
      <h2>Doctor Information</h2>
      <div>
        <p><strong>Email:</strong> {{doctorEmail}}</p>
      </div>
    </div>

    <div class='section'>
      <h2>Patient Information</h2>

      <div class='info-row'>
        <div class='field'>
          <span class='label'>Email</span>
          <span>{{patientEmail}}</span>
        </div>

        <div class='field'>
          <span class='label'>DNI</span>
          <span>{{patientDNI}}</span>
        </div>
      </div>
    </div>

    <div class='section'>
      <h2>Notes</h2>
      <p>{{notes}}</p>
    </div>

    <div class='section'>
      <h2>Medications</h2>

      {{#if items.length}}
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Dosage</th>
              <th>Quantity</th>
              <th>Instructions</th>
            </tr>
          </thead>

          <tbody>
            {{#each items}}
              <tr>
                <td>{{name}}</td>
                <td>{{dosage}}</td>
                <td>{{quantity}}</td>
                <td>{{instructions}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}

        <p>No medications registered.</p>

      {{/if}}
    </div>

    <div class='signature-section'>
      <div class='signature-box'>
        {{#if doctorSignatureUrl}}
          <img src='{{doctorSignatureUrl}}' alt='Doctor Signature' class='signature-image' />
        {{/if}}

        <div class='signature-line'></div>

        <p class='signature-label'>
          Physician Signature
        </p>

        <p class='signature-name'>
          {{doctorEmail}}
        </p>
      </div>
    </div>
  </body>
</html>
